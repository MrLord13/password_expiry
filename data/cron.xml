<odoo>

    <record id="ir_cron_password_expiry_email"
            model="ir.cron">

        <field name="name">Password Expiry Reminder</field>

        <field name="model_id"
               ref="base.model_res_users"/>

        <field name="state">code</field>

        <field name="code">
model.send_password_expiry_email()
        </field>

        <field name="interval_number">1</field>

        <field name="interval_type">days</field>

        <field name="active">True</field>

    </record>

</odoo>