<odoo>

    <record id="password_expiry_email_template"
            model="mail.template">

        <field name="name">Password Expiry Reminder</field>

        <field name="model_id"
               ref="base.model_res_users"/>

        <field name="subject">Password Expiry Warning</field>

        <field name="email_to">${object.email}</field>

        <field name="body_html" type="html">
<div>
    <p>Hello ${object.name}</p>

    <p>
        Your password will expire soon.
    </p>

    <p>
        Please change your password.
    </p>
</div>
        </field>

    </record>

</odoo>